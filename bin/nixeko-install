#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
#  nixeko-install — commission your vessel
#  Run from the NixOS ISO after cloning the nixeko repo.
#  Usage: bash bin/nixeko-install
# ─────────────────────────────────────────────────────────────────────────────

set -Eeuo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SHIP_NAME=""
CAPTAIN=""           # unix username
PROFILE=""           # nixeko | nixeko-dinghy | nixeko-beacon
TARGET_DISK=""
ROOT_PART=""
EFI_PART=""
LUKS_ENABLED=false
LUKS_PASS=""
LUKS_UUID=""
MAPPER="nixeko-vault"
INSTALL_MODE=""      # full | dual
HW_MODULE=""         # nixos-hardware module name, or empty
HAS_NVIDIA=false
IS_VM=false
CURRENT_STEP="startup"
LOGFILE="/tmp/nixeko-install.log"
STEPS_TOTAL=17
SPINNER_PID=""

# ── Colors (NES palette) ──────────────────────────────────────────────────────
RED='\033[0;31m'; GRN='\033[0;32m'; YLW='\033[1;33m'
CYN='\033[0;36m'; WHT='\033[1;37m'; DIM='\033[2m'
BLD='\033[1m';    ITL='\033[3m';    RST='\033[0m'

# ── Output helpers ────────────────────────────────────────────────────────────
say()    { echo -e "\n${ITL}${DIM}  $*${RST}"; sleep 0.4; }
ok()     { echo -e "${GRN}  ✓  $*${RST}"; }
warn()   { echo -e "${YLW}  ⚠  $*${RST}"; }
err()    { echo -e "${RED}  ✗  $*${RST}" >&2; cleanup_mounts 2>/dev/null; exit 1; }
prompt() { echo -e "\n${WHT}${BLD}  ›  $*${RST}"; }
rule()   { echo -e "${DIM}  ────────────────────────────────────────${RST}"; }
dim()    { echo -e "  ${DIM}$*${RST}"; }

# ── Progress bar ──────────────────────────────────────────────────────────────
_pbar() {
  local n=$1 total=$2 width=22 i filled bar=""
  filled=$(( n * width / total ))
  for ((i=0; i<filled; i++));     do bar+="█"; done
  for ((i=filled; i<width; i++)); do bar+="░"; done
  echo -e "  ${DIM}[${CYN}${bar}${DIM}]  ${n}/${total}${RST}"
}

# ── Section header — hdr N "TITLE" ───────────────────────────────────────────
_roman() {
  local -a R=('' I II III IV V VI VII VIII IX X XI XII XIII XIV XV XVI XVII XVIII)
  echo "${R[$1]}"
}

hdr() {
  local n=$1; shift
  stop_spinner
  echo -e "\n${BLD}${CYN}  ══  $(_roman "$n"). $*  ══${RST}"
  _pbar "$n" "$STEPS_TOTAL"
  echo ""
}

# ── Spinner ───────────────────────────────────────────────────────────────────
_SF=(⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏)

start_spinner() {
  local msg="$1"
  local tty; tty=$(tty 2>/dev/null || echo /dev/tty)
  stop_spinner
  (
    local i=0
    while true; do
      printf "\r  ${CYN}%s${RST}  ${DIM}%s${RST}" "${_SF[$((i%10))]}" "$msg" >"$tty"
      sleep 0.08
      (( i++ )) || true
    done
  ) &
  SPINNER_PID=$!
  disown "$SPINNER_PID" 2>/dev/null || true
}

stop_spinner() {
  [[ -z "${SPINNER_PID:-}" ]] && return 0
  kill "$SPINNER_PID" 2>/dev/null || true
  wait "$SPINNER_PID" 2>/dev/null || true
  SPINNER_PID=""
  local tty; tty=$(tty 2>/dev/null || echo /dev/tty)
  printf "\r\033[2K" >"$tty"
}

# ── Error handling ────────────────────────────────────────────────────────────

cleanup_mounts() {
  umount -R /mnt 2>/dev/null || true
  cryptsetup close "$MAPPER" 2>/dev/null || true
}

on_error() {
  local line="$1"
  stop_spinner
  echo ""
  echo -e "  ${RED}${BLD}╔══════════════════════════════════════════════╗${RST}"
  echo -e "  ${RED}${BLD}║  ✗  Commission interrupted                   ║${RST}"
  echo -e "  ${RED}${BLD}╚══════════════════════════════════════════════╝${RST}"
  echo -e "  ${DIM}  step ${CURRENT_STEP}  ·  line ${line}${RST}"
  echo ""
  cleanup_mounts
  echo ""
  case "$CURRENT_STEP" in
    "IX")
      warn "Disk partitioning failed."
      dim "Is the disk in use?   lsblk"
      dim "Confirm it exists:    ls ${TARGET_DISK}"
      ;;
    "X")
      warn "LUKS encryption failed — partition may be locked or already open."
      dim "Check state:  lsblk -o NAME,TYPE,FSTYPE"
      dim "Close stale:  cryptsetup close ${MAPPER}"
      ;;
    "XI")
      warn "Filesystem creation failed — something is still mounted."
      dim "Fix:  umount -R /mnt && udevadm settle"
      ;;
    "XII")
      warn "Could not load the manifest. Disk space?"
      dim "Check:  df -h /mnt"
      ;;
    "XIII:hardware-scan")
      warn "nixos-generate-config failed."
      dim "Is /mnt mounted?  mount | grep /mnt"
      dim "Is /mnt/boot mounted?  mount | grep boot"
      ;;
    "XIII:hostname-patch")
      warn "Could not patch hostname — host config file missing."
      dim "Expected:  hosts/${PROFILE}/default.nix"
      dim "Did copy_repo succeed?  ls /mnt/home/${CAPTAIN}/Projects/nixeko/hosts/"
      ;;
    "XIII:hardware-config-copy")
      warn "Could not copy hardware-configuration.nix."
      dim "Did nixos-generate-config write to /mnt/etc/nixos/?"
      dim "Check:  ls /mnt/etc/nixos/"
      ;;
    "XIII:flake-patch")
      warn "Could not patch flake.nix."
      dim "Check:  ls /mnt/home/${CAPTAIN}/Projects/nixeko/flake.nix"
      ;;
    "XV")
      warn "Failed to patch LUKS config into hardware-configuration.nix."
      dim "Check:  cat /mnt/home/${CAPTAIN}/Projects/nixeko/hosts/${PROFILE}/hardware-configuration.nix"
      dim "UUID:   ${LUKS_UUID}"
      ;;
    "XVI")
      warn "nixos-install failed. The error above has the full story."
      echo ""
      dim "Common causes:"
      dim "  · Config error  — cd into the repo and run:  nix flake check"
      dim "  · No network    — check connectivity and retry"
      dim "  · Disk full     — df -h /mnt"
      echo ""
      dim "To retry without re-running the whole wizard:"
      dim "  mount /dev/mapper/${MAPPER} /mnt   (or /dev/${TARGET_DISK##*/}2 if no LUKS)"
      dim "  mount ${EFI_PART:-/dev/...} /mnt/boot"
      dim "  git -C /mnt/home/${CAPTAIN}/Projects/nixeko add -A"
      dim "  nixos-install --no-root-passwd \\"
      dim "    --flake \"/mnt/home/${CAPTAIN}/Projects/nixeko#${PROFILE}\""
      ;;
    "XVII")
      warn "Password setup failed. Set it manually:"
      dim "  nixos-enter --root /mnt"
      dim "  passwd ${CAPTAIN}"
      ;;
    *)
      warn "Something unexpected failed. Check the output above for details."
      ;;
  esac
  echo ""
  if [[ -f "$LOGFILE" ]]; then
    echo -e "  ${DIM}── last log lines ─────────────────────────────────────────────${RST}"
    tail -20 "$LOGFILE" | sed 's/\x1b\[[0-9;]*m//g' | sed 's/^/    /'
    echo -e "  ${DIM}───────────────────────────────────────────────────────────────${RST}"
    echo ""
    dim "Full log: ${LOGFILE}"
  fi
  echo ""
  dim "Mounts cleared. Run the wizard again when ready."
  echo ""
}

trap 'on_error $LINENO' ERR

# Read a password into a named variable — shows ✦ per character, supports backspace
# Usage: read_secret VARNAME
read_secret() {
  local __var="$1"
  local __pass=""
  local __char
  local __tty
  __tty=$(tty 2>/dev/null || echo /dev/tty)
  stty -echo <"$__tty" 2>/dev/null || true   # kill echo BEFORE any input
  printf '  ' >"$__tty"
  while IFS= read -r -s -n1 __char <"$__tty"; do
    if [[ -z "$__char" ]]; then
      break
    elif [[ "$__char" == $'\x7f' || "$__char" == $'\b' ]]; then
      if [[ -n "$__pass" ]]; then
        __pass="${__pass%?}"
        printf '\b \b' >"$__tty"
      fi
    else
      __pass+="$__char"
      printf "${CYN}✦${RST}" >"$__tty"
    fi
  done
  stty echo <"$__tty" 2>/dev/null || true    # restore echo after
  printf '\n' >"$__tty"
  printf -v "$__var" '%s' "$__pass"
}

