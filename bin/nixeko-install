# ── Guards ────────────────────────────────────────────────────────────────────

check_root() {
  [[ $EUID -eq 0 ]] || err "Must run as root. Try: sudo bash bin/nixeko-install"
}

check_environment() {
  say "Something stirs in the deep. Systems coming online..."
  systemd-detect-virt --quiet 2>/dev/null && IS_VM=true || true
  $IS_VM && dim "Virtual environment detected. Hardware-specific steps will be skipped."
  if ! command -v nixos-install &>/dev/null; then
    warn "nixos-install not found — are you running from the NixOS ISO?"
    warn "This wizard is designed for the NixOS installation environment."
    echo ""
    prompt "Continue anyway? [y/N]"
    read -r ans
    [[ "${ans,,}" == "y" ]] || exit 0
  else
    ok "NixOS installation environment confirmed."
  fi
}

# ── Step 1: Name your ship ─────────────────────────────────────────────────────

name_ship() {
  hdr 1 "THE VESSEL"
  say "Every ship that crosses the expanse carries a name. Whispered in logs,\n  etched in manifests. Yours will echo further than you know."
  echo ""
  while true; do
    prompt "Name your vessel (hostname, no spaces):"
    read -r SHIP_NAME
    SHIP_NAME="${SHIP_NAME// /-}"
    SHIP_NAME="${SHIP_NAME,,}"
    if [[ -z "$SHIP_NAME" ]]; then
      warn "A ship without a name is just debris."
    elif [[ ! "$SHIP_NAME" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
      warn "Lowercase letters, numbers, hyphens only."
    else
      ok "The ${BLD}${SHIP_NAME}${RST}${GRN} awaits commission."
      break
    fi
  done

  echo ""
  say "And the captain? Your unix username — this becomes your home directory."
  echo ""
  while true; do
    prompt "Captain's name (username):"
    read -r CAPTAIN
    CAPTAIN="${CAPTAIN// /-}"
    CAPTAIN="${CAPTAIN,,}"
    if [[ -z "$CAPTAIN" ]]; then
      warn "Every crew needs a captain."
    elif [[ ! "$CAPTAIN" =~ ^[a-z][a-z0-9-]*$ ]]; then
      warn "Lowercase letters, numbers, hyphens only. Must start with a letter."
    else
      ok "Captain ${BLD}${CAPTAIN}${RST}${GRN} — at your command."
      break
    fi
  done
}

# ── Step 2: Choose your loadout ───────────────────────────────────────────────

select_profile() {
  hdr 2 "THE LOADOUT"
  say "What kind of vessel are you commissioning?"
  echo ""
  echo -e "    ${BLD}1${RST}  ${CYN}nixeko${RST}         Full Hyprland — all stations manned. ${DIM}(default)${RST}"
  echo -e "    ${BLD}2${RST}  ${CYN}nixeko-dinghy${RST}  BSPWM — nimble craft, same waters, lighter hull."
  echo -e "    ${BLD}3${RST}  ${CYN}nixeko-beacon${RST}  Headless — hull and engines only. No bridge."
  echo ""
  while true; do
    prompt "Choose [1/2/3] (default: 1):"
    read -r profile_choice
    profile_choice="${profile_choice:-1}"
    case "$profile_choice" in
      1) PROFILE="nixeko";         ok "Full vessel. All hands on deck."; break ;;
      2) PROFILE="nixeko-dinghy";  ok "The dinghy. Swift, lean, ready."; break ;;
      3) PROFILE="nixeko-beacon";  ok "Beacon mode. Silent running."; break ;;
      *) warn "Choose 1, 2, or 3." ;;
    esac
  done
}

# ── Step 3: Hardware detection ────────────────────────────────────────────────

detect_hardware_module() {
  # Skip for beacon (headless — hardware modules less critical)
  [[ "$PROFILE" == "nixeko-beacon" ]] && return

  hdr 3 "HULL SCAN"
  say "Reading the machine's manifest. Identifying the hull class..."
  echo ""

  if $IS_VM; then
    dim "Skipping on virtual hardware — runs on real machines only."
    return
  fi

  local product
  product=$(dmidecode -s system-product-name 2>/dev/null | tr '[:upper:]' '[:lower:]' | xargs || echo "")

  # Known hardware module map
  local detected=""
  case "$product" in
    *"g15 5530"*|*"g15-5530"*)     detected="dell-g15-5530" ;;
    *"g15 5520"*|*"g15-5520"*)     detected="dell-g15-5520" ;;
    *"xps 15"*)                    detected="dell-xps-15-9510" ;;
    *"xps 13"*)                    detected="dell-xps-13-9310" ;;
    *"thinkpad x1 carbon"*)        detected="lenovo-thinkpad-x1-carbon-gen11" ;;
    *"thinkpad t14"*)              detected="lenovo-thinkpad-t14-amd-gen4" ;;
    *"thinkpad p1"*)               detected="lenovo-thinkpad-p1-gen6" ;;
    *"framework"*|*"13th gen"*"framework"*) detected="framework-13-7040-amd" ;;
    *"surface pro"*)               detected="microsoft-surface-pro-9" ;;
    *"pavilion"*|*"dm1"*)          detected="hp-pavilion-gaming-15-dk0xxx" ;;
    *"envy"*)                      detected="hp-envy-x360-13-ay0xxx" ;;
    *"zephyrus"*)                  detected="asus-zephyrus-g14-ga401" ;;
  esac

  if [[ -n "$detected" ]]; then
    ok "Hull class detected: ${BLD}${product}${RST}"
    ok "Hardware module:     ${BLD}${detected}${RST}"
    echo ""
    prompt "Apply this hardware module? [Y/n]:"
    read -r hw_ans
    if [[ "${hw_ans,,}" != "n" ]]; then
      HW_MODULE="$detected"
      ok "Module confirmed."
      return
    fi
  else
    warn "Hull class not recognised: ${DIM}${product:-unknown}${RST}"
  fi

  echo ""
  say "You can specify a nixos-hardware module manually, or skip.\n  Browse all modules: github.com/nixos/nixos-hardware"
  echo ""
  prompt "Hardware module name (or leave blank to skip):"
  read -r hw_input
  if [[ -n "$hw_input" ]]; then
    HW_MODULE="$hw_input"
    ok "Module set: ${BLD}${HW_MODULE}${RST}"
  else
    dim "No hardware module. Continuing with generic config."
  fi
}

# ── Step 4: NVIDIA ────────────────────────────────────────────────────────────

detect_nvidia_question() {
  [[ "$PROFILE" == "nixeko-beacon" ]] && return
  $IS_VM && return

  hdr 4 "ENGINE ROOM"
  say "Does this vessel carry twin engines? Intel iGPU + NVIDIA GPU (hybrid / Optimus)?"
  echo ""

  # Try to auto-detect
  if lspci 2>/dev/null | grep -qiE "3D.*NVIDIA|VGA.*NVIDIA"; then
    ok "NVIDIA GPU detected."
    echo ""
    prompt "Enable NVIDIA PRIME offload support? [Y/n]:"
    read -r nv_ans
    [[ "${nv_ans,,}" != "n" ]] && HAS_NVIDIA=true
  else
    prompt "Do you have an NVIDIA GPU? [y/N]:"
    read -r nv_ans
    [[ "${nv_ans,,}" == "y" ]] && HAS_NVIDIA=true
  fi

  if $HAS_NVIDIA; then
    ok "NVIDIA support enabled. Bus IDs will be auto-detected and patched."
  else
    dim "No NVIDIA module. Intel/AMD only."
  fi
}

# ── Step 5: Choose the expanse ────────────────────────────────────────────────

select_disk() {
  hdr 5 "THE EXPANSE"
  say "The substrate stretches before you. Choose where the ${SHIP_NAME} shall be carved."
  echo ""
  echo -e "  ${DIM}Available drives:${RST}"
  echo ""
  lsblk -d -o NAME,SIZE,MODEL,ROTA --noheadings | while read -r name size model rota; do
    local type="SSD"
    [[ "$rota" == "1" ]] && type="HDD"
    printf "    ${BLD}%-10s${RST}  ${CYN}%8s${RST}  ${DIM}%-30s  %s${RST}\n" \
      "/dev/$name" "$size" "$model" "$type"
  done
  echo ""
  while true; do
    prompt "Target drive (e.g. sda, nvme0n1):"
    read -r disk_input
    TARGET_DISK="/dev/${disk_input#/dev/}"
    if [[ -b "$TARGET_DISK" ]]; then
      ok "Target: ${BLD}${TARGET_DISK}${RST}"
      break
    else
      warn "Device ${TARGET_DISK} not found."
    fi
  done
}

# ── Step 6: Full conquest or shared expanse ───────────────────────────────────

select_install_mode() {
  hdr 6 "TERRITORY"
  say "Will the ${SHIP_NAME} claim the entire expanse, or sail alongside another?"
  echo ""
  echo -e "    ${BLD}1${RST}  Full conquest   — entire drive is yours. All prior data lost."
  echo -e "    ${BLD}2${RST}  Shared expanse  — install alongside existing OS (dual boot)."
  echo ""
  while true; do
    prompt "Choose [1/2]:"
    read -r mode_choice
    case "$mode_choice" in
      1) INSTALL_MODE="full";  ok "Full conquest. The void will be reshaped."; break ;;
      2) INSTALL_MODE="dual";  ok "Shared expanse. The old world will remain."; break ;;
      *) warn "Choose 1 or 2." ;;
    esac
  done

  if [[ "$INSTALL_MODE" == "dual" ]]; then
    echo ""
    say "The existing partition table:"
    echo ""
    lsblk "$TARGET_DISK" -o NAME,SIZE,FSTYPE,LABEL,MOUNTPOINT
    echo ""
    say "You need two things: an EFI partition and a root partition for NixOS.\n  If you haven't created the NixOS partition yet, exit and use a partition\n  tool first. The EFI partition can be shared with the existing OS."
    echo ""

    while true; do
      prompt "NixOS root partition (e.g. sda3, nvme0n1p3):"
      read -r root_input
      ROOT_PART="/dev/${root_input#/dev/}"
      [[ -b "$ROOT_PART" ]] && { ok "Root: ${BLD}${ROOT_PART}${RST}"; break; }
      warn "Partition ${ROOT_PART} not found."
    done

    echo ""
    say "Scanning for EFI partition..."
    EFI_PART=$(lsblk "$TARGET_DISK" -o NAME,FSTYPE --noheadings | \
      awk '$2=="vfat"{print "/dev/"$1}' | head -1)

    if [[ -n "$EFI_PART" ]]; then
      ok "EFI partition found: ${BLD}${EFI_PART}${RST}"
    else
      warn "No EFI partition detected automatically."
      while true; do
        prompt "EFI partition (e.g. sda1, nvme0n1p1):"
        read -r efi_input
        EFI_PART="/dev/${efi_input#/dev/}"
        [[ -b "$EFI_PART" ]] && { ok "EFI: ${BLD}${EFI_PART}${RST}"; break; }
        warn "Partition ${EFI_PART} not found."
      done
    fi
  fi
}

# ── Step 4: Hull integrity ─────────────────────────────────────────────────────

choose_encryption() {
  hdr 7 "HULL INTEGRITY"
  say "The vault can be sealed. No force may breach it without the passphrase.\n  Recommended. The expanse is not always friendly."
  echo ""
  prompt "Seal the hull with encryption? [Y/n]:"
  read -r enc_choice
  if [[ "${enc_choice,,}" != "n" ]]; then
    LUKS_ENABLED=true
    echo ""
    say "Choose your passphrase wisely. Lose it and the vault is lost forever."
    echo ""
    while true; do
      prompt "Passphrase:"
      read_secret LUKS_PASS
      prompt "Confirm passphrase:"
      read_secret LUKS_CONFIRM
      if [[ "$LUKS_PASS" == "$LUKS_CONFIRM" ]]; then
        [[ ${#LUKS_PASS} -ge 8 ]] || { warn "Passphrase too short (min 8 chars)."; continue; }
        ok "Passphrase set. The hull will be sealed."
        break
      else
        warn "Passphrases do not match. Try again."
      fi
    done
  else
    ok "No encryption. The hull remains open."
  fi
}

# ── Step 5: Final confirmation ────────────────────────────────────────────────

confirm_plan() {
  hdr 8 "FINAL MANIFEST"
  say "Before the commission begins, review the charter."
  echo ""
  echo -e "    ${BLD}Ship name${RST}     ${CYN}${SHIP_NAME}${RST}"
  echo -e "    ${BLD}Captain${RST}       ${CYN}${CAPTAIN}${RST}"
  echo -e "    ${BLD}Profile${RST}       ${CYN}${PROFILE}${RST}"
  echo -e "    ${BLD}Target${RST}        ${CYN}${TARGET_DISK}${RST}"
  echo -e "    ${BLD}Mode${RST}          ${CYN}${INSTALL_MODE}${RST}"
  [[ -n "$HW_MODULE" ]] && echo -e "    ${BLD}HW module${RST}     ${CYN}${HW_MODULE}${RST}"
  $HAS_NVIDIA && echo -e "    ${BLD}NVIDIA${RST}        ${CYN}PRIME offload${RST}"
  if [[ "$INSTALL_MODE" == "dual" ]]; then
    echo -e "    ${BLD}Root part${RST}     ${CYN}${ROOT_PART}${RST}"
    echo -e "    ${BLD}EFI part${RST}      ${CYN}${EFI_PART}${RST}"
  fi
  if $LUKS_ENABLED; then
    echo -e "    ${BLD}Encryption${RST}    ${GRN}LUKS2 — hull sealed${RST}"
  else
    echo -e "    ${BLD}Encryption${RST}    ${YLW}none${RST}"
  fi
  echo ""
  if [[ "$INSTALL_MODE" == "full" ]]; then
    echo -e "  ${RED}${BLD}  ⚠  ALL DATA ON ${TARGET_DISK} WILL BE DESTROYED.${RST}"
    echo ""
  fi
  prompt "Commit to this charter? [yes/N]:"
  read -r confirm
  [[ "${confirm,,}" == "yes" ]] || { say "Commission aborted. The void remains unchanged."; exit 0; }
}

# ── Step 6: Shape the void ────────────────────────────────────────────────────

partition_disk() {
  if [[ "$INSTALL_MODE" != "full" ]]; then return; fi
  CURRENT_STEP="IX"
  hdr 9 "SHAPING THE VOID"
  say "The expanse yields to form. Carving decks and holds..."
  echo ""

  start_spinner "Partitioning ${TARGET_DISK}..."
  sgdisk --zap-all "$TARGET_DISK"
  sgdisk -n 1:0:+512M  -t 1:ef00 -c 1:"EFI"  "$TARGET_DISK"
  sgdisk -n 2:0:0       -t 2:8300 -c 2:"root" "$TARGET_DISK"
  partprobe "$TARGET_DISK" 2>/dev/null || true
  udevadm settle
  sleep 1
  stop_spinner

  # Derive partition names (handles both /dev/sdX and /dev/nvme0nX)
  if [[ "$TARGET_DISK" == *"nvme"* || "$TARGET_DISK" == *"mmc"* ]]; then
    EFI_PART="${TARGET_DISK}p1"
    ROOT_PART="${TARGET_DISK}p2"
  else
    EFI_PART="${TARGET_DISK}1"
    ROOT_PART="${TARGET_DISK}2"
  fi

  ok "EFI:  ${EFI_PART}"
  ok "Root: ${ROOT_PART}"
}

# ── Step 7: Seal the hull ──────────────────────────────────────────────────────

seal_hull() {
  if ! $LUKS_ENABLED; then return; fi
  CURRENT_STEP="X"
  hdr 10 "SEALING THE HULL"
  echo ""

  umount -R /mnt 2>/dev/null || true
  cryptsetup close "$MAPPER" 2>/dev/null || true
  swapoff "$ROOT_PART" 2>/dev/null || true
  umount "$ROOT_PART" 2>/dev/null || true
  udevadm settle

  local _keyfile
  _keyfile=$(mktemp)
  printf '%s' "$LUKS_PASS" > "$_keyfile"

  start_spinner "Formatting vault..."
  cryptsetup luksFormat \
    --type luks2 \
    --batch-mode \
    --key-file="$_keyfile" \
    "$ROOT_PART"
  stop_spinner; ok "Vault formatted."

  start_spinner "Opening vault..."
  cryptsetup open \
    --batch-mode \
    --key-file="$_keyfile" \
    "$ROOT_PART" \
    "$MAPPER"
  stop_spinner; ok "Vault open."

  shred -u "$_keyfile"

  LUKS_UUID=$(blkid -s UUID -o value "$ROOT_PART")
  ok "Hull sealed. UUID: ${DIM}${LUKS_UUID}${RST}"
}

# ── Step 8: Lay the decks ─────────────────────────────────────────────────────

format_and_mount() {
  CURRENT_STEP="XI"
  hdr 11 "LAYING THE DECKS"
  say "The chambers take shape. Floors, walls, the spaces between."
  echo ""

  # Full cleanup — graphical ISO mounts everything it sees
  umount -R /mnt 2>/dev/null || true
  umount "$EFI_PART" 2>/dev/null || true
  umount "$ROOT_PART" 2>/dev/null || true
  udevadm settle

  start_spinner "Formatting EFI partition..."
  mkfs.fat -F 32 -n EFI "$EFI_PART"
  stop_spinner
  ok "EFI formatted."

  if $LUKS_ENABLED; then
    start_spinner "Formatting root (inside vault)..."
    mkfs.ext4 -L nixeko "/dev/mapper/${MAPPER}" >/dev/null
    stop_spinner
    ok "Root formatted (inside vault)."
    start_spinner "Mounting..."
    mount "/dev/mapper/${MAPPER}" /mnt
  else
    start_spinner "Formatting root partition..."
    mkfs.ext4 -L nixeko "$ROOT_PART" >/dev/null
    stop_spinner
    ok "Root formatted."
    start_spinner "Mounting..."
    mount "$ROOT_PART" /mnt
  fi

  mkdir -p /mnt/boot
  mount "$EFI_PART" /mnt/boot
  stop_spinner
  ok "Decks mounted."
}

# ── Step 9: Copy the manifest ─────────────────────────────────────────────────

copy_repo() {
  CURRENT_STEP="XII"
  hdr 12 "LOADING THE MANIFEST"
  say "The ship's charter — every setting, every configuration — is carried aboard."
  echo ""

  mkdir -p "/mnt/home/$CAPTAIN/Projects"
  start_spinner "Copying nixeko to ~/Projects/nixeko..."
  cp -r "$REPO_DIR" "/mnt/home/$CAPTAIN/Projects/nixeko"
  stop_spinner
  ok "Manifest loaded to ~/Projects/nixeko"
}

patch_username() {
  local dest="/mnt/home/$CAPTAIN/Projects/nixeko"

  say "Configuring for captain: ${CAPTAIN}..."

  local files=(
    "$dest/flake.nix"
    "$dest/home/eko.nix"
    "$dest/home/dinghy.nix"
    "$dest/home/beacon.nix"
    "$dest/home/scripts.nix"
    "$dest/hosts/nixeko/default.nix"
    "$dest/hosts/nixeko-dinghy/default.nix"
    "$dest/hosts/nixeko-beacon/default.nix"
    "$dest/hosts/nixeko-vm/default.nix"
    "$dest/modules/system/base.nix"
    "$dest/modules/system/vpn.nix"
  )

  for f in "${files[@]}"; do
    [[ -f "$f" ]] && sed -i "s/\beko\b/$CAPTAIN/g" "$f"
  done

  if [[ "$CAPTAIN" != "eko" && -f "$dest/home/eko.nix" ]]; then
    mv "$dest/home/eko.nix" "$dest/home/$CAPTAIN.nix"
    sed -i "s|./home/eko.nix|./home/$CAPTAIN.nix|g" "$dest/flake.nix"
  fi

  ok "Configuration ready for captain: ${CAPTAIN}"
}

# ── Step 10: VPN provisioning ─────────────────────────────────────────────────

setup_vpn() {
  hdr 13 "THE CLOAKING ARRAY"
  say "A ship that moves unseen moves safely. The array accepts any OpenVPN\n  configuration — ProtonVPN, Mullvad, your own. Or skip and add later."
  echo ""
  prompt "Set up VPN now? [y/N]:"
  read -r vpn_choice
  if [[ "${vpn_choice,,}" != "y" ]]; then
    say "The cloaking array stands by. Configure later via vpn/README.md."
    return
  fi

  local dest_dir="/mnt/home/$CAPTAIN/Projects/nixeko/vpn"

  echo ""
  say "Where are your .ovpn files? Provide a path — USB mount, /tmp, anywhere."
  say "Leave blank to skip and add manually after install."
  echo ""
  prompt "Path to .ovpn files (directory or leave blank):"
  read -r ovpn_path

  if [[ -n "$ovpn_path" ]]; then
    if [[ -d "$ovpn_path" ]]; then
      local count
      count=$(find "$ovpn_path" -maxdepth 1 -name "*.ovpn" | wc -l)
      if [[ "$count" -eq 0 ]]; then
        warn "No .ovpn files found in ${ovpn_path}. Skipping."
      else
        cp "$ovpn_path"/*.ovpn "$dest_dir/configs/"
        ok "${count} config(s) loaded into the array."
      fi
    else
      warn "Directory not found: ${ovpn_path}. Skipping configs."
    fi
  fi

  echo ""
  say "Credentials bind the array to your account.\n  For ProtonVPN: use your OpenVPN credentials (not your login password).\n  Found at account.proton.me → VPN → Downloads → OpenVPN credentials."
  echo ""
  prompt "Enter VPN username (or leave blank to skip):"
  read -r vpn_user

  if [[ -n "$vpn_user" ]]; then
    prompt "Enter VPN password:"
    read_secret vpn_pass
    printf '%s\n%s\n' "$vpn_user" "$vpn_pass" > "$dest_dir/credentials"
    chmod 600 "$dest_dir/credentials"
    ok "Credentials stored. The array is armed."
  else
    say "No credentials set. Add them later to vpn/credentials."
  fi
}

# ── Step 11: Chart the vessel ─────────────────────────────────────────────────

generate_config() {
  CURRENT_STEP="XIII:hardware-scan"
  hdr 13 "CHARTING THE VESSEL"
  say "Scanning ship systems... cataloguing drives, engines, memory cells..."
  echo ""

  start_spinner "Scanning hardware..."
  nixos-generate-config --root /mnt
  stop_spinner
  ok "Hardware manifest generated."

  # Patch hostname
  CURRENT_STEP="XIII:hostname-patch"
  local host_file="/mnt/home/$CAPTAIN/Projects/nixeko/hosts/${PROFILE}/default.nix"
  if [[ ! -f "$host_file" ]]; then
    err "Host config not found: ${host_file}\n  Did copy_repo succeed? Is PROFILE='${PROFILE}' correct?"
  fi
  sed -i "s/networking.hostName = \"[^\"]*\"/networking.hostName = \"${SHIP_NAME}\"/" \
    "$host_file"
  ok "Ship registered as: ${BLD}${SHIP_NAME}${RST}"

  # Copy generated hardware-configuration.nix into the nixeko repo
  CURRENT_STEP="XIII:hardware-config-copy"
  cp /mnt/etc/nixos/hardware-configuration.nix \
    "/mnt/home/$CAPTAIN/Projects/nixeko/hosts/${PROFILE}/hardware-configuration.nix"
  ok "Hardware configuration captured."

  # Patch flake.nix — inject hardware module if detected
  CURRENT_STEP="XIII:flake-patch"
  local flake="/mnt/home/$CAPTAIN/Projects/nixeko/flake.nix"
  if [[ -n "$HW_MODULE" ]]; then
    sed -i "s|# NIXOS_HARDWARE: none|nixos-hardware.nixosModules.${HW_MODULE}|g" "$flake"
    ok "Hardware module patched: ${BLD}${HW_MODULE}${RST}"
  fi

  if $HAS_NVIDIA; then
    sed -i "s|# NVIDIA_MODULE: none|./modules/system/nvidia.nix|g" "$flake"
    ok "NVIDIA module patched."
  fi
}

# ── Step 12: Detect engines ───────────────────────────────────────────────────

detect_nvidia() {
  $HAS_NVIDIA || return 0

  hdr 14 "TWIN ENGINES"
  say "Probing the drive systems... listening for the twin engines..."
  echo ""

  local intel_id nvidia_id
  intel_id=$(lspci | grep -E "VGA.*Intel" | awk '{print $1}' | head -1)
  nvidia_id=$(lspci | grep -E "3D.*NVIDIA|VGA.*NVIDIA" | awk '{print $1}' | head -1)

  if [[ -n "$intel_id" && -n "$nvidia_id" ]]; then
    # Convert PCI address format: 00:02.0 → PCI:0:2:0
    local intel_nix nvidia_nix
    intel_nix=$(echo "$intel_id" | awk -F'[:\.]' '{printf "PCI:%d:%d:%d", strtonum("0x"$1), strtonum("0x"$2), strtonum("0x"$3)}')
    nvidia_nix=$(echo "$nvidia_id" | awk -F'[:\.]' '{printf "PCI:%d:%d:%d", strtonum("0x"$1), strtonum("0x"$2), strtonum("0x"$3)}')

    local nvidia_file="/mnt/home/$CAPTAIN/Projects/nixeko/modules/system/nvidia.nix"
    sed -i "s|intelBusId = \"[^\"]*\"|intelBusId = \"${intel_nix}\"|" "$nvidia_file"
    sed -i "s|nvidiaBusId = \"[^\"]*\"|nvidiaBusId = \"${nvidia_nix}\"|" "$nvidia_file"

    ok "Primary engine (Intel):  ${BLD}${intel_nix}${RST}"
    ok "Shadow engine (NVIDIA):  ${BLD}${nvidia_nix}${RST}"
  else
    warn "Twin engines not detected — nvidia.nix bus IDs unchanged."
    warn "Update manually if needed: modules/system/nvidia.nix"
  fi
}

# ── Step 13: Patch LUKS into boot config ──────────────────────────────────────

patch_luks_config() {
  if ! $LUKS_ENABLED; then return; fi
  CURRENT_STEP="XV"

  hdr 15 "SEALING THE BOOT VAULT"
  echo ""

  local hw_file="/mnt/home/$CAPTAIN/Projects/nixeko/hosts/${PROFILE}/hardware-configuration.nix"
  if ! grep -q "luks" "$hw_file"; then
    # Strip the closing } and append LUKS config + closing }
    local tmp
    tmp=$(mktemp)
    head -n -1 "$hw_file" > "$tmp"
    printf '\n  boot.initrd.luks.devices."%s" = {\n    device = "/dev/disk/by-uuid/%s";\n    allowDiscards = true;\n  };\n\n}\n' \
      "$MAPPER" "$LUKS_UUID" >> "$tmp"
    mv "$tmp" "$hw_file"
    ok "Hull seal patched into boot configuration."
  else
    ok "Hull seal already present in hardware configuration."
  fi
}

# ── Step 14: Launch ───────────────────────────────────────────────────────────

run_install() {
  CURRENT_STEP="XVI"
  hdr 16 "IGNITION"
  say "All systems nominal. The ${SHIP_NAME} draws her first breath."
  echo ""
  dim "This will take a while. Nix is downloading and building the full system."
  dim "You'll see build output scroll past — that's normal. Don't interrupt it."
  dim "If it pauses for a minute, it's probably fetching a large package."
  echo ""

  # Stage all generated/patched files so Nix's git fetcher can see them.
  # (Nix uses `git ls-files` which includes staged files but not untracked ones.)
  git -C "/mnt/home/$CAPTAIN/Projects/nixeko" add -A 2>/dev/null || true

  nixos-install \
    --no-root-passwd \
    --flake "/mnt/home/$CAPTAIN/Projects/nixeko#${PROFILE}"

  echo ""
  ok "Installation complete."
}

# ── Set user password ─────────────────────────────────────────────────────────

set_password() {
  CURRENT_STEP="XVII"
  hdr 17 "THE CAPTAIN'S SEAL"
  say "Set your login password for captain ${BLD}${CAPTAIN}${RST}${ITL}${DIM}."
  echo ""

  while true; do
    prompt "Password:"
    read_secret _pw1
    prompt "Confirm:"
    read_secret _pw2
    if [[ "$_pw1" != "$_pw2" ]]; then
      warn "Passwords do not match. Try again."
      continue
    fi
    [[ ${#_pw1} -ge 4 ]] || { warn "Too short (min 4 chars)."; continue; }
    printf '%s:%s\n' "$CAPTAIN" "$_pw1" | nixos-enter --root /mnt -- chpasswd
    ok "Password set for ${CAPTAIN}."
    break
  done

  echo ""
  say "Set a root password? Useful for recovery from TTY.\n  If skipped, use sudo with your user password instead."
  echo ""
  prompt "Set root password? [y/N]:"
  read -r root_pw_choice
  if [[ "${root_pw_choice,,}" == "y" ]]; then
    while true; do
      prompt "Root password:"
      read_secret _rp1
      prompt "Confirm:"
      read_secret _rp2
      if [[ "$_rp1" != "$_rp2" ]]; then
        warn "Passwords do not match. Try again."
        continue
      fi
      [[ ${#_rp1} -ge 4 ]] || { warn "Too short (min 4 chars)."; continue; }
      printf 'root:%s\n' "$_rp1" | nixos-enter --root /mnt -- chpasswd
      ok "Root password set."
      break
    done
  else
    dim "Root login disabled. Use: sudo -i"
  fi
}

# ── Farewell ──────────────────────────────────────────────────────────────────

farewell() {
  # Save install log into the new system
  if [[ -f "$LOGFILE" && -d /mnt ]]; then
    mkdir -p "/mnt/home/$CAPTAIN"
    cp "$LOGFILE" "/mnt/home/$CAPTAIN/nixeko-install.log" 2>/dev/null || true
  fi

  # Summary table
  local enc_label nv_label
  $LUKS_ENABLED && enc_label="encrypted" || enc_label="none"
  $HAS_NVIDIA   && nv_label="yes"        || nv_label="no"
  echo ""
  echo -e "  ${DIM}╔════════════════════════════════════════╗${RST}"
  echo -e "  ${DIM}║${RST}  ${DIM}ship        ${RST}  ${BLD}${CYN}${SHIP_NAME}${RST}"
  echo -e "  ${DIM}║${RST}  ${DIM}profile     ${RST}  ${WHT}${PROFILE}${RST}"
  echo -e "  ${DIM}║${RST}  ${DIM}captain     ${RST}  ${WHT}${CAPTAIN}${RST}"
  echo -e "  ${DIM}║${RST}  ${DIM}disk        ${RST}  ${WHT}${TARGET_DISK}${RST}"
  if $LUKS_ENABLED; then
    echo -e "  ${DIM}║${RST}  ${DIM}encryption  ${RST}  ${GRN}${enc_label}${RST}"
  else
    echo -e "  ${DIM}║${RST}  ${DIM}encryption  ${RST}  ${DIM}${enc_label}${RST}"
  fi
  if $HAS_NVIDIA; then
    echo -e "  ${DIM}║${RST}  ${DIM}nvidia      ${RST}  ${GRN}${nv_label}${RST}"
  else
    echo -e "  ${DIM}║${RST}  ${DIM}nvidia      ${RST}  ${DIM}${nv_label}${RST}"
  fi
  echo -e "  ${DIM}╚════════════════════════════════════════╝${RST}"
  echo ""
  rule
  farewell_art "$SHIP_NAME"
  say "The ${BLD}${SHIP_NAME}${RST}${ITL}${DIM} is yours now, Captain."
  say "She carries everything — the manifest, the charts, the vault."
  say "Cast off when ready."
  echo ""
  echo -e "  ${DIM}After reboot:${RST}"
  echo -e "  ${CYN}  nixeko doctor${RST}          — run a full health check"
  echo -e "  ${CYN}  nixeko theme <name>${RST}     — change the colour of the deep"
  echo -e "  ${CYN}  nixeko wallpaper <f>${RST}    — set the viewport"
  echo ""
  if $LUKS_ENABLED; then
    echo -e "  ${YLW}  Passphrase required at each launch. Guard it well.${RST}"
    echo ""
  fi
  rule
  echo ""
}

# ── Main ──────────────────────────────────────────────────────────────────────

main() {
  exec > >(tee -a "$LOGFILE") 2>&1
  show_title
  check_root
  check_environment
  name_ship
  select_profile
  detect_hardware_module
  detect_nvidia_question
  select_disk
  select_install_mode
  choose_encryption
  confirm_plan
  partition_disk
  seal_hull
  format_and_mount
  copy_repo
  patch_username
  generate_config
  detect_nvidia
  patch_luks_config
  run_install
  set_password
  farewell
}

main "$@"
